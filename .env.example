FUNPAY_COOKIES=golden_key=your_funpay_cookie; PHPSESSID=your_session
FUNPAY_BASE_URL=https://funpay.com
FUNPAY_ORDERS_PATH=/orders/
FUNPAY_HTTP_TIMEOUT=30

FRAGMENT_COOKIES=stel_ssid=your_fragment_cookie
FRAGMENT_BASE_URL=https://fragment.com
FRAGMENT_HEADLESS=true

TWIBOOST_BASE_URL=https://twiboost.com
TWIBOOST_API_KEY=
TWIBOOST_CREATE_ORDER_PATH=/api/orders
TWIBOOST_STATUS_PATH=/api/orders/{order_id}
TWIBOOST_USERNAME=
TWIBOOST_PASSWORD=

DATABASE_PATH=data/bot.sqlite3
POLLING_INTERVAL=10
NETWORK_RETRIES=3
RETRY_DELAY=3
LOG_LEVEL=INFO
